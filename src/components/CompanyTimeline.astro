---
interface TimelineItem {
  period: string;
  company: string;
  role: string;
}
interface Props {
  items: TimelineItem[];
}
const { items } = Astro.props;
---

<div class="relative pl-8 border-l-2 border-[#c1c1c1]">
  {items.map((item, i) => (
    <div class={`relative pb-8 ${i === items.length - 1 ? 'pb-0' : ''}`}>
      <div class="absolute -left-[25px] w-4 h-4 rounded-full bg-[#ff385c] border-2 border-base-100"></div>
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-sm font-bold">{item.period}</span>
        <span class="text-base-content/30">·</span>
        <span class="text-base font-semibold">{item.company}</span>
      </div>
      <p class="text-sm text-base-content/60 mt-1">{item.role}</p>
    </div>
  ))}
</div>
