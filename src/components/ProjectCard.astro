---
interface Props {
  title: string;
  summary: string;
  accentColor?: string;
  details: string[];
}
const { title, summary, accentColor, details } = Astro.props;
---

<div class="collapse collapse-arrow bg-base-200 mb-3">
  <input type="checkbox" aria-label={`展开 ${title}`} />
  <div class="collapse-title">
    <div class="font-semibold" style={`color: ${accentColor || 'var(--brand-text)'}; word-break: break-word; overflow-wrap: break-word;`}>{title}</div>
    <p class="text-sm text-base-content/60 mt-1" style="word-break: break-word; overflow-wrap: break-word;">{summary}</p>
  </div>
  <div class="collapse-content">
    <ul class="list-disc list-inside space-y-2 text-sm">
      {details.map((d) => (
        <li set:html={d} />
      ))}
    </ul>
  </div>
</div>
