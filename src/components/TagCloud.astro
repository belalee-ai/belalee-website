---
interface Tag {
  label: string;
  size: "xl" | "lg" | "md" | "sm" | "xs";
  logo?: string;
}
interface Props {
  tags: Tag[];
}
const { tags } = Astro.props;

const sizeClasses = {
  xl: "text-lg px-5 py-2.5 font-bold bg-[#ff385c] text-white",
  lg: "text-base px-4 py-2 font-semibold bg-[#ff6b81] text-white",
  md: "text-sm px-3 py-1.5 bg-[#f2f2f2] text-[#222222]",
  sm: "text-xs px-3 py-1.5 bg-[#f2f2f2] text-[#222222]",
  xs: "text-xs px-2.5 py-1 bg-[#f2f2f2] text-[#6a6a6a]"
};
---

<div class="flex flex-wrap gap-3 justify-center">
  {tags.map((tag) => (
    <span class={`tag-cloud-item inline-flex items-center gap-1.5 rounded-full transition-transform hover:scale-105 ${sizeClasses[tag.size]}`}>
      {tag.logo && <img src={tag.logo} alt={tag.label} class="w-4 h-4" />}
      {tag.label}
    </span>
  ))}
</div>
