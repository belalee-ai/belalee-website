---
const { title, img, desc, url, badge, tags, target = "_blank" } = Astro.props;
import { Image } from "astro:assets";
const tag_url = url.split("/").slice(0, -1).join("/") + "/tag";

const badgeColors: Record<string, string> = {
  "商业化": "var(--brand-text)",
  "增长": "var(--brand-text)",
  "出海": "var(--brand-text)",
  "工作流": "var(--brand-text)",
  "AI 转型": "var(--brand-text)",
};
const badgeColor = badge ? (badgeColors[badge] || "var(--brand-text)") : "";
---

<div class="card-row group">
  <a href={url} target={target} rel={target === "_blank" ? "noopener noreferrer" : undefined} class="block">
    <div class="hero-content flex-col md:flex-row items-center">
      {
        img && (
          <Image
            src={img}
            width={750}
            height={422}
            format="webp"
            alt={title}
            class="max-w-full md:max-w-[13rem] rounded-lg"
          />
        )
      }
      <div class="grow w-full">
        <div class="flex items-center gap-2 mb-0.5">
          {badge && <span class="card-badge" style={`color: ${badgeColor}; border-left-color: ${badgeColor};`}>{badge}</span>}
          <h2 class="text-base font-semibold text-base-content/80 leading-snug line-clamp-2" style="word-break: break-word; overflow-wrap: break-word;">{title}</h2>
        </div>
        <p class="text-sm text-base-content/60 leading-relaxed line-clamp-2" style="word-break: break-word; overflow-wrap: break-word;">{desc}</p>
        {tags && tags.length > 0 && (
          <div class="card-tags-inline">
            {tags.map((tag, i) => (
              <><a href={`${tag_url}/${tag}`} class="card-tag-link">{tag}</a>{i < tags.length - 1 && <span class="card-tag-sep">·</span>}</>
            ))}
          </div>
        )}
      </div>
      <span class="card-row-arrow">›</span>
    </div>
  </a>
</div>
