---
// Page navigation order - must match sidebar menu order
const pages = [
  { path: '/', id: 'home' },
  { path: '/projects', id: 'projects' },
  { path: '/blog', id: 'blog' },
  { path: '/skills', id: 'skills' },
  { path: '/ai-toolkit', id: 'ai-toolkit' },
  { path: '/ai-lab', id: 'ai-lab' },
  { path: '/cv', id: 'cv' },
  { path: '/contact', id: 'contact' },
];

const { sideBarActiveItemID } = Astro.props;
const currentIndex = pages.findIndex(p => p.id === sideBarActiveItemID);
const prevPage = currentIndex > 0 ? pages[currentIndex - 1] : null;
const nextPage = currentIndex < pages.length - 1 ? pages[currentIndex + 1] : null;
---

{/* Next page hint at bottom */}
{nextPage && (
  <a href={nextPage.path} class="page-scroll-hint page-scroll-hint--next">
    <span class="page-scroll-hint__arrow">↓</span>
    <span class="page-scroll-hint__label">继续浏览</span>
  </a>
)}

<script define:vars={{ nextPath: nextPage?.path || '' }}>
  document.addEventListener('astro:page-load', () => {
    if (!nextPath) return;

    // Reveal hint when it scrolls into view (visual nicety only)
    const trigger = document.querySelector('.page-scroll-hint--next');
    if (!trigger) return;

    const observer = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          trigger.classList.add('visible');
        } else {
          trigger.classList.remove('visible');
        }
      });
    }, { threshold: 0.3 });

    setTimeout(() => {
      observer.observe(trigger);
    }, 800);
  });
</script>

<style>
  .page-scroll-hint {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    padding: 1.5rem 0 1rem;
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 400ms cubic-bezier(0.25, 0.1, 0.25, 1), transform 400ms cubic-bezier(0.25, 0.1, 0.25, 1);
    cursor: pointer;
    user-select: none;
    text-decoration: none;
    color: inherit;
  }

  .page-scroll-hint.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .page-scroll-hint__arrow {
    font-size: 1.25rem;
    color: #c1c1c1;
    animation: arrow-pulse 2.4s cubic-bezier(0.25, 0.1, 0.25, 1) infinite;
  }

  .page-scroll-hint__label {
    font-size: 0.75rem;
    color: #6a6a6a;
    letter-spacing: 0.1em;
  }

  @keyframes arrow-pulse {
    0%, 100% { opacity: 0.55; transform: translateY(0); }
    50%      { opacity: 1;    transform: translateY(2px); }
  }

  @media (prefers-reduced-motion: reduce) {
    .page-scroll-hint__arrow {
      animation: none;
    }
  }
</style>
