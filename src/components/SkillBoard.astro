---
interface Skill {
  label: string;
  level: number; // 1-5
  logo?: string;
}

interface Category {
  title: string;
  icon: string;
  skills: Skill[];
}

interface Props {
  categories: Category[];
}

const { categories } = Astro.props;
---

<div class="skill-board">
  {categories.map((cat, ci) => {
    const accents = [
      { bar: '#ff385c, #e00b41', border: 'rgba(0,0,0,0.08)' },
      { bar: '#ff385c, #e00b41', border: 'rgba(0,0,0,0.08)' },
      { bar: '#ff385c, #e00b41', border: 'rgba(0,0,0,0.08)' },
      { bar: '#ff385c, #e00b41', border: 'rgba(0,0,0,0.08)' },
    ];
    const accent = accents[ci % accents.length];
    return (
    <div class="skill-card" style={`animation-delay: ${ci * 0.1}s; --bar-gradient: linear-gradient(90deg, ${accent.bar}); --header-border: ${accent.border};`}>
      <div class="skill-card__header">
        <span class="skill-card__icon">{cat.icon}</span>
        <h3 class="skill-card__title">{cat.title}</h3>
      </div>
      <div class="skill-card__list">
        {cat.skills.map((skill) => (
          <div class="skill-item">
            <div class="skill-item__info">
              {skill.logo && <img src={skill.logo} alt="" class="skill-item__logo" />}
              <span class="skill-item__label">{skill.label}</span>
            </div>
            <div class="skill-item__bar-bg">
              <div
                class="skill-item__bar-fill"
                style={`width: ${skill.level * 20}%`}
              />
            </div>
          </div>
        ))}
      </div>
    </div>
    );
  })}
</div>

<style>
  .skill-board {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  @media (max-width: 640px) {
    .skill-board {
      grid-template-columns: 1fr;
    }
  }

  .skill-card {
    background: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 20px;
    padding: 1.5rem;
    animation: cardSlideUp 0.5s cubic-bezier(0.25, 0.1, 0.25, 1) both;
    transition: box-shadow 0.3s ease, transform 0.2s ease;
  }

  .skill-card:hover {
    box-shadow: rgba(0,0,0,0.02) 0px 0px 0px 1px, rgba(0,0,0,0.04) 0px 2px 6px, rgba(0,0,0,0.1) 0px 4px 8px;
    transform: translateY(-2px);
  }

  @keyframes cardSlideUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .skill-card__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 1.2rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--header-border, rgba(0,0,0,0.08));
  }

  .skill-card__icon {
    font-size: 1.25rem;
  }

  .skill-card__title {
    font-size: 0.95rem;
    font-weight: 600;
    color: #222222;
    letter-spacing: 0.03em;
  }

  .skill-card__list {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .skill-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    min-width: 0;
  }

  .skill-item__info {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    width: 6.5rem;
    flex-shrink: 0;
    overflow: hidden;
  }

  .skill-item__logo {
    width: 1rem;
    height: 1rem;
    flex-shrink: 0;
  }

  .skill-item__label {
    font-size: 0.72rem;
    color: #6a6a6a;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .skill-item__bar-bg {
    flex: 1;
    min-width: 3rem;
    height: 6px;
    background: #f2f2f2;
    border-radius: 3px;
    overflow: hidden;
  }

  .skill-item__bar-fill {
    height: 100%;
    border-radius: 3px;
    background: var(--bar-gradient, linear-gradient(90deg, #ff385c, #e00b41));
    transition: width 0.8s cubic-bezier(0.25, 0.1, 0.25, 1);
  }
</style>
