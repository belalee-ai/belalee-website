---
import BaseLayout from "../layouts/BaseLayout.astro";
import CompanyTimeline from "../components/CompanyTimeline.astro";
import ProjectCard from "../components/ProjectCard.astro";

const companies = [
  {
    period: "近 3 年",
    company: "某头部电商平台",
    role: "C端增长产品经理 · 搜索增长 & 海外广告投放"
  },
  {
    period: "约 2 年",
    company: "某影像科技公司",
    role: "影像商业产品经理 · 会员体系从0到1 & 订阅中台"
  },
  {
    period: "约 1 年",
    company: "某新零售品牌",
    role: "产品经理 · 营销体系 & 付费会员搭建"
  }
];

const projects = [
  {
    title: "广告投放与 ROI 优化",
    summary: "某电商平台欧区 Facebook 广告 · ROAS 115%+ · 日花费 $8K+",
    colorClass: "text-primary",
    details: [
      "构建以 ROAS 出价为核心的出价体系，<strong>单条头部广告日花费 $5K+，ROAS 稳定 110%+</strong>",
      "转盘抽奖、限时赠品等互动玩法，<strong>支付 UV 提升 ~10%，人均 GMV 增长 ~20%</strong>",
      "落地页策略优化，<strong>激活率提升至 10%+，UV 转化率提升 ~4%</strong>",
      "头部广告复制组策略快速放大（预算提升至日均 3-8 倍），尾部广告 2-3 天无起色即关停",
      "建立 ASC 底层兜底 + 定向广告补充的广告架构，控制同系列广告 ≤5 条，避免内耗",
      "基于 eCPM 竞价逻辑持续优化 CTR、CVR、ROI，通过分时漏斗和诊断看板实时监控"
    ]
  },
  {
    title: "订阅商业化",
    summary: "某影像 APP 会员体系 · 付费收入 +35% · 订阅中台搭建",
    colorClass: "text-secondary",
    details: [
      "多层用户精细化分层 + 订阅引导策略组合，<strong>会员转化率提升 15%+，付费收入提升 30%+</strong>",
      "第三方支付外显策略，<strong>该渠道付费占比提高 ~25%，年收入新增百万级</strong>",
      "节日活动合辑工具，B 端分钟级上线全年活动，<strong>为大盘新增年收入 15%+</strong>",
      "会员召回策略（挽留弹窗 + 过期限免），<strong>召回率从个位数提升至 10%+</strong>",
      "从 0 到 1 搭建订阅中台（多个核心模块），<strong>新 APP 接入周期缩短约一半</strong>",
      "主导核心 APP 会员体系从 0 到 1 搭建（支付、权益、等级、管理）"
    ]
  },
  {
    title: "搜索增长",
    summary: "某电商平台搜索 · GMV +10%+ · 搜索全链路优化",
    colorClass: "text-accent",
    details: [
      "优化搜索推荐词刷新机制，<strong>GMV 提升 10%+，订单量提升近 10%</strong>",
      "店铺评价页「搜同款」功能，<strong>全站收入与支付 GMV 均有显著提升</strong>",
      "主导图搜「月销量排序」策略，图搜 GMV 稳步增长",
      "购后推荐搭配模块，GMV 与订单量双向拉升",
      "推动商品标题结构化展示（品牌 + 卖点 + 价格区间），GMV 正向提升",
      "搜索结果页「再次购买」按钮，拉动全站收入"
    ]
  },
  {
    title: "出海活动增长",
    summary: "某电商平台欧洲区 · 激活率 10%+ · 跨文化本地化",
    colorClass: "text-info",
    details: [
      "端外落地页下载条优化，<strong>日均曝光 UV 百万级，互动率提升 15%+</strong>",
      "负责欧洲区广告落地页策略，<strong>激活率提升至 10%+，UV 转化率提升 ~4%</strong>",
      "购物车拦截策略（软/硬拦截），<strong>支付率提升 ~8%，GMV 增长 ~9%</strong>",
      "活动商品与发券策略调优，<strong>人均 GMV 与总支付用户数均稳步提升</strong>",
      "支付页利益点外显（包邮、优惠券），<strong>日均 GMV 正向增长</strong>",
      "跨文化本地化增长运营（Email、App Push、SMS、WhatsApp 多渠道营销触达）"
    ]
  }
];
---

<BaseLayout sideBarActiveItemID="projects">
  <div class="pb-12 mt-5">
    <div class="text-3xl font-bold mb-6 text-base-content/80">项目经历</div>

    <div class="mb-10">
      <div class="text-lg font-semibold mb-4 tracking-wide">从业足迹</div>
      <CompanyTimeline items={companies} />
    </div>

    <div>
      <div class="text-lg font-semibold mb-4 tracking-wide">核心项目</div>
      {projects.map((p, i) => {
        const accents = [
          'oklch(0.55 0.10 180)',
          'oklch(0.52 0.10 260)',
          'oklch(0.58 0.12 50)',
          'oklch(0.55 0.10 30)',
        ];
        return (
        <ProjectCard
          title={p.title}
          summary={p.summary}
          colorClass={p.colorClass}
          accentColor={accents[i % accents.length]}
          details={p.details}
        />
        );
      })}
    </div>
  </div>
</BaseLayout>
