---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";

// Priority order: core expertise first
const priorityOrder: Record<string, number> = {
  "商业化": 1,
  "增长": 2,
  "出海": 3,
  "工作流": 4,
  "AI 转型": 5,
};

const posts = (await getCollection("blog")).sort((a, b) => {
  const pa = priorityOrder[a.data.badge || ""] || 99;
  const pb = priorityOrder[b.data.badge || ""] || 99;
  if (pa !== pb) return pa - pb;
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

const badgeAccents: Record<string, { color: string; bg: string }> = {
  "商业化": { color: "#222222", bg: "rgba(0,0,0,0.04)" },
  "增长": { color: "#222222", bg: "rgba(0,0,0,0.04)" },
  "出海": { color: "#222222", bg: "rgba(0,0,0,0.04)" },
  "工作流": { color: "#222222", bg: "rgba(0,0,0,0.04)" },
  "AI 转型": { color: "#222222", bg: "rgba(0,0,0,0.04)" },
};
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-center hero-gradient">
      <div class="avatar mb-6">
        <div class="w-20 rounded-full ring-2 ring-accent/30 ring-offset-base-100 ring-offset-2 mx-auto">
          <img src="/profile.jpg" alt="梨贝拉" />
        </div>
      </div>
      <h1 class="text-4xl font-bold tracking-wide"><span class="inline-block">🍐</span>梨贝拉</h1>
      <p class="text-base mt-4 tracking-widest">
        <span style="color: #222222;">效果广告</span>
        <span class="text-base-content/25"> ｜ </span>
        <span style="color: #222222;">订阅商业化</span>
        <span class="text-base-content/25"> ｜ </span>
        <span style="color: #222222;">出海增长</span>
      </p>
      <p class="text-sm mt-5 text-base-content/60 leading-relaxed max-w-md mx-auto">
        6年+ C端增长与商业化实战，前拼多多/TEMU · 美图秀秀 · 瑞幸咖啡<br/>
        打造AI时代的增长飞轮
      </p>
      <div class="flex gap-4 justify-center mt-8">
        <a href="/contact" class="btn btn-sm gap-1 hero-btn hero-btn-primary">联系我 <span class="text-xs">→</span></a>
        <a href="/cv" class="btn btn-sm btn-ghost gap-1 hero-btn">查看简历 <span class="text-xs">→</span></a>
      </div>
    </div>
  </div>

  <div class="home-sections">
    <!-- AI 洞察 -->
    <div class="home-section">
      <div class="home-section__header">
        <h2 class="home-section__title">AI 洞察</h2>
        <a href="/blog" class="home-section__more">All →</a>
      </div>
      <div class="home-insights">
        {posts.map((post, i) => (
          <a href={"/blog/" + createSlug(post.data.title, post.slug)} class="home-insight-item">
            <span class="home-insight-num">{String(i + 1).padStart(2, '0')}</span>
            <span class="home-insight-badge" style={`color: ${badgeAccents[post.data.badge || ""]?.color || ""}; background: ${badgeAccents[post.data.badge || ""]?.bg || ""};`}>{post.data.badge}</span>
            <span class="home-insight-title">{post.data.title}</span>
            <span class="home-insight-arrow">→</span>
          </a>
        ))}
      </div>
    </div>

    <!-- AI 实验室 -->
    <div class="home-section">
      <div class="home-section__header">
        <h2 class="home-section__title">AI 实验室</h2>
        <a href="/ai-lab" class="home-section__more">All →</a>
      </div>
      <div class="home-carousel" id="home-carousel" aria-roledescription="轮播" aria-label="AI 实验室项目">
        <button class="carousel-arrow carousel-arrow--left" id="carousel-prev" aria-label="上一个">‹</button>
        <button class="carousel-arrow carousel-arrow--right" id="carousel-next" aria-label="下一个">›</button>
        <div class="home-carousel__track" id="home-carousel-track">
          <a href="/ai-lab/personal-site" class="home-carousel__slide">
            <div class="home-lab-card__cover">
              <img src="/works/site-cover.png" alt="AI 协作建站" loading="lazy" />
            </div>
            <div class="home-lab-card__body">
              <span class="home-lab-card__status">已上线</span>
              <h3 class="home-lab-card__title">AI 协作建站</h3>
              <p class="home-lab-card__desc">零代码基础，全程 AI 协作完成设计、开发、内容</p>
              <div class="home-lab-card__tools">
                <span>Claude</span><span>Astro</span><span>Vercel</span>
              </div>
            </div>
          </a>
          <div class="home-carousel__slide home-carousel__slide--soon">
            <div class="home-lab-card__cover home-lab-card__cover--placeholder"><span>📈</span></div>
            <div class="home-lab-card__body">
              <span class="home-lab-card__status home-lab-card__status--soon">筹备中</span>
              <h3 class="home-lab-card__title">AI 增长实验看板</h3>
              <p class="home-lab-card__desc">基于 AI 的增长数据分析与实验管理工具</p>
              <div class="home-lab-card__tools"><span>Claude</span><span>React</span></div>
            </div>
          </div>
          <div class="home-carousel__slide home-carousel__slide--soon">
            <div class="home-lab-card__cover home-lab-card__cover--placeholder"><span>📝</span></div>
            <div class="home-lab-card__body">
              <span class="home-lab-card__status home-lab-card__status--soon">筹备中</span>
              <h3 class="home-lab-card__title">Prompt 工作流模板库</h3>
              <p class="home-lab-card__desc">产品经理常用 Prompt 模板与自动化工作流</p>
              <div class="home-lab-card__tools"><span>ChatGPT</span><span>Claude</span></div>
            </div>
          </div>
        </div>
        <div class="home-carousel__dots" id="home-carousel-dots">
          <button class="home-carousel__dot active" data-index="0" aria-label="幻灯片 1" type="button"></button>
          <button class="home-carousel__dot" data-index="1" aria-label="幻灯片 2" type="button"></button>
          <button class="home-carousel__dot" data-index="2" aria-label="幻灯片 3" type="button"></button>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    document.addEventListener('astro:page-load', function() {
      var track = document.getElementById('home-carousel-track');
      var dots = document.querySelectorAll('#home-carousel-dots .home-carousel__dot');
      var prevBtn = document.getElementById('carousel-prev');
      var nextBtn = document.getElementById('carousel-next');
      if (!track || dots.length === 0) return;

      var current = 0;
      var total = dots.length;
      var timer;
      var prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      function goTo(index) {
        current = ((index % total) + total) % total;
        track.style.transform = 'translateX(-' + (current * 100) + '%)';
        dots.forEach(function(d, i) {
          if (i === current) d.classList.add('active');
          else d.classList.remove('active');
        });
      }

      function startAuto() {
        if (prefersReducedMotion) return;
        timer = setInterval(function() { goTo(current + 1); }, 4000);
      }

      function resetAuto() {
        clearInterval(timer);
        startAuto();
      }

      dots.forEach(function(dot) {
        dot.addEventListener('click', function() {
          goTo(parseInt(dot.getAttribute('data-index') || '0'));
          resetAuto();
        });
      });

      if (prevBtn) {
        prevBtn.addEventListener('click', function() {
          goTo(current - 1);
          resetAuto();
        });
      }

      if (nextBtn) {
        nextBtn.addEventListener('click', function() {
          goTo(current + 1);
          resetAuto();
        });
      }

      startAuto();

      // Pause auto-play on hover/focus (WCAG 2.2.2)
      var carousel = document.getElementById('home-carousel');
      if (carousel) {
        carousel.addEventListener('mouseenter', function() { clearInterval(timer); });
        carousel.addEventListener('mouseleave', function() { resetAuto(); });
        carousel.addEventListener('focusin', function() { clearInterval(timer); });
        carousel.addEventListener('focusout', function() { resetAuto(); });
      }
    });
  </script>
</BaseLayout>
